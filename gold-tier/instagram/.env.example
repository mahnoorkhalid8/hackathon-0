# Facebook App Credentials
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here
FACEBOOK_REDIRECT_URI=https://localhost/

# Instagram Business Credentials (obtained after OAuth flow)
INSTAGRAM_BUSINESS_ID=your_business_id_here
INSTAGRAM_ACCESS_TOKEN=your_access_token_here
IG_TOKEN_EXPIRES_AT=2026-12-31T00:00:00Z

# Optional: Facebook Page ID (obtained during auth)
FB_PAGE_ID=your_page_id_here
